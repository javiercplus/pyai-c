async def do_web_search(query: str) -> str:
    """Búsqueda real en DuckDuckGo usando el paquete actualizado"""
    try:
        # FIX 1: Usar 'ddgs' en vez del paquete obsoleto 'duckduckgo_search'
        from ddgs import DDGS
        
        def _search():
            results = []
            with DDGS() as ddgs:
                for r in ddgs.text(query, max_results=5):
                    results.append(r)
            
            if not results:
                return "No se encontraron resultados."
            
            text = "=== RESULTADOS DE BÚSQUEDA WEB ===\n\n"
            for i, r in enumerate(results, 1):
                title = r.get("title", "Sin título")
                body = r.get("body", "Sin descripción")
                href = r.get("href", "")
                text += f"[{i}] {title}\n{body}\nFuente: {href}\n\n"
            
            return text
        
        loop = asyncio.get_event_loop()
        return await loop.run_in_executor(None, _search)
        
    except Exception as e:
        print(f"[SEARCH ERROR] {e}")
        return f"Error en búsqueda: {e}"

def detect_search_needed(message: str):
    """Detecta si necesita búsqueda y retorna el query"""
    if not message:
        return None
    
    msg_lower = message.lower()
    
    keywords = [
        "precio", "cuanto cuesta", "cuánto cuesta", "valor", "cotizacion",
        "hoy", "ahora", "actualmente", "actual", "este momento",
        "noticia", "noticias", "ultimo", "último", "reciente",
        "bitcoin", "btc", "ethereum", "eth", "crypto", "criptomoneda",
        "dolar", "dólar", "euro", "peso", "bolsa", "stock",
        "clima", "tiempo", "temperatura",
        "busca", "buscar", "investiga", "búscame", "google",
        "quien es", "quién es", "que es", "qué es",
        "price", "cost", "today", "now", "current", "latest",
        "news", "weather", "search", "find", "look up",
        "2024", "2025"
    ]
    
    for kw in keywords:
        if kw in msg_lower:
            # FIX 2: Limpiar mejor el query (quitar "busca", "el", "la", etc.)
            query = message.strip()
            query = re.sub(r'^[¿¡?!,.\s]+', '', query)
            query = re.sub(r'[¿¡?!,.\s]+$', '', query)
            
            # Quitar verbos de comando
            query = re.sub(
                r'^(puedes?\s*(busca|buscar|decir|decirme|dime)|busca|buscar|investiga|búscame|dime|cuéntame|cuentame|tell me|can you|please|search for|look up)\s*', 
                '', query, flags=re.IGNORECASE
            )
            
            # Quitar artículos innecesarios al inicio
            query = re.sub(r'^(el|la|los|las|de|del|en)\s+', '', query, flags=re.IGNORECASE)
            
            query = query.strip()
            
            if len(query) >= 3:
                return query
    
    return None

@proxy_app.post("/v1/chat/completions")
async def chat_completions(request: Request):
    """Endpoint principal con búsqueda integrada"""
    try:
        body = await request.json()
        messages = body.get("messages", [])
        stream = body.get("stream", False)
        
        # Obtener último mensaje del usuario
        last_message = ""
        for msg in reversed(messages):
            if msg.get("role") == "user":
                last_message = msg.get("content", "")
                break
        
        print(f"\n[MSG] {last_message[:80]}...")
        
        # Detectar si necesita búsqueda
        search_query = detect_search_needed(last_message)
        
        if search_query:
            print(f"[🔍 BUSCANDO] '{search_query}'")
            search_results = await do_web_search(search_query)
            print(f"[✅ RESULTADOS] {len(search_results)} caracteres")
            
            # FIX 3: Solo inyectar si hay resultados reales y útiles
            if "No se encontraron" not in search_results and "Error" not in search_results and len(search_results) > 50:
                context_msg = {
                    "role": "system",
                    "content": f"\n=== INFORMACIÓN WEB ACTUALIZADA ===\n{search_results}\n=== FIN INFORMACIÓN ===\n\nIMPORTANTE: Usa esta información actualizada para responder. Si preguntaron por un precio o dato actual, da la información exacta que aparece arriba."
                }
                
                # Insertar después del primer system message o al inicio
                modified_messages = []
                inserted = False
                for msg in messages:
                    modified_messages.append(msg)
                    if msg.get("role") == "system" and not inserted:
                        modified_messages.append(context_msg)
                        inserted = True
                
                if not inserted:
                    modified_messages.insert(0, {
                        "role": "system",
                        "content": "Eres un asistente útil con acceso a internet."
                    })
                    modified_messages.insert(1, context_msg)
                
                body["messages"] = modified_messages
                print("[💉 CONTEXTO INYECTADO]")
            else:
                print("[⚠️ SIN RESULTADOS ÚTILES]")
        else:
            print("[💬 RESPUESTA DIRECTA]")
        
        # Forward al servidor Llama
        async with httpx.AsyncClient(timeout=600.0) as client:
            if stream:
                async with client.stream("POST", f"{LLAMA_URL}/v1/chat/completions", json=body) as response:
                    async def generate():
                        async for chunk in response.aiter_bytes():
                            yield chunk
                    return StreamingResponse(generate(), media_type="text/event-stream")
            else:
                response = await client.post(f"{LLAMA_URL}/v1/chat/completions", json=body)
                result = response.json()
                
                # Log de respuesta
                if "choices" in result and result["choices"]:
                    content = result["choices"][0].get("message", {}).get("content", "")
                    print(f"[🤖 RESP] {content[:100]}...")
                
                return JSONResponse(content=result)
                
    except httpx.ConnectError:
        print("[❌ ERROR] No se puede conectar al servidor Llama")
        return JSONResponse(status_code=503, content={"error": "Servidor Llama no disponible"})
    except Exception as e:
        print(f"[❌ ERROR] {type(e).__name__}: {e}")
        return JSONResponse(status_code=500, content={"error": str(e)})

@proxy_app.post("/v1/search")
async def manual_search(request: Request):
    """Búsqueda manual"""
    body = await request.json()
    query = body.get("query", "")
    results = await do_web_search(query)
    return {"query": query, "results": results}

@proxy_app.get("/v1/models")
async def models():
    try:
        async with httpx.AsyncClient(timeout=10.0) as client:
            r = await client.get(f"{LLAMA_URL}/v1/models")
            return r.json()
    except:
        return {"data": [{"id": "coder-web", "object": "model"}]}

@proxy_app.api_route("/{path:path}", methods=["GET", "POST"])
async def proxy_catchall(request: Request, path: str):
    try:
        async with httpx.AsyncClient(timeout=600.0) as client:
            url = f"{LLAMA_URL}/{path}"
            if request.method == "GET":
                r = await client.get(url, params=dict(request.query_params))
            else:
                body = await request.json()
                r = await client.post(url, json=body)
            return JSONResponse(content=r.json())
    except Exception as e:
        return JSONResponse(status_code=500, content={"error": str(e)})

