def verify_gpu():
    print("\n🎮 Verificando GPU...")
    result = subprocess.run(
        "nvidia-smi --query-gpu=name,memory.free --format=csv,noheader",
        shell=True, capture_output=True, text=True
    )
    if result.returncode == 0 and result.stdout.strip():
        for line in result.stdout.strip().split('\n'):
            print(f"   ✅ {line}")
        return True
    print("   ❌ Sin GPU")
    return False

def setup_environment():
    print("\n📦 Paso 1: Instalando...")
    
    # CUDA paths
    cuda_libs = subprocess.run(
        "find /usr -name 'libcudart.so*' 2>/dev/null | head -3",
        shell=True, capture_output=True, text=True
    )
    if cuda_libs.stdout:
        lib_dirs = set(os.path.dirname(l) for l in cuda_libs.stdout.strip().split('\n'))
        os.environ["LD_LIBRARY_PATH"] = ":".join(lib_dirs) + ":" + os.environ.get("LD_LIBRARY_PATH", "")
    
    # FIX 1: Instalar 'ddgs' en vez de 'duckduckgo-search'
    subprocess.run("pip install fastapi uvicorn requests tqdm ddgs httpx -q", shell=True)
    subprocess.run(
        "pip install llama-cpp-python[server] --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cu121 --prefer-binary -q",
        shell=True
    )
    
    # Descargar modelo
    print(f"\n📥 Paso 2: Descargando modelo...")
    headers = {}
    modo = 'wb'
    descargado = 0
    
    if os.path.exists(MODEL_PATH):
        descargado = os.path.getsize(MODEL_PATH)
        headers['Range'] = f'bytes={descargado}-'
        modo = 'ab'

    resp = requests.get(URL_MODELO, stream=True, headers=headers)
    
    if resp.status_code == 416:
        print("   ✅ Ya descargado")
    elif resp.status_code in [200, 206]:
        total = int(resp.headers.get('content-length', 0)) + descargado
        with open(MODEL_PATH, modo) as f, tqdm(desc="   ", total=total, initial=descargado, unit='iB', unit_scale=True, ncols=70) as bar:
            for chunk in resp.iter_content(chunk_size=1024*1024):
                bar.update(f.write(chunk))
        print(f"   ✅ {os.path.getsize(MODEL_PATH)/(1024**3):.2f} GB")

def start_llama_server():
    print(f"\n🚀 Paso 3: Cargando modelo...")
    
    cmd = [
        "python", "-m", "llama_cpp.server",
        "--model", MODEL_PATH,
        "--n_ctx", "8192",
        "--n_gpu_layers", "99",
        "--host", "127.0.0.1",
        "--port", str(LLAMA_PORT)
    ]
    
    proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True, bufsize=1, env=os.environ.copy())
    
    for line in proc.stdout:
        print(f"   {line.rstrip()}")
        if any(x in line for x in ["Uvicorn running", "startup complete"]):
            print("\n   ✅ Llama listo!")
            break
        if "libcudart" in line or "out of memory" in line.lower():
            proc.terminate()
            raise RuntimeError("Error GPU")
    
    threading.Thread(target=lambda: [x for x in proc.stdout], daemon=True).start()
    return proc

def start_proxy_server():
    """Inicia el proxy directamente (sin archivo separado)"""
    print(f"\n🌐 Paso 4: Iniciando proxy con búsqueda web...")
    
    def run():
        uvicorn.run(proxy_app, host="0.0.0.0", port=PROXY_PORT, log_level="warning")
    
    thread = threading.Thread(target=run, daemon=True)
    thread.start()
    
    # Esperar a que esté listo
    time.sleep(4)
    
    # Verificar que responde
    try:
        r = requests.get(f"http://127.0.0.1:{PROXY_PORT}/v1/models", timeout=5)
        if r.status_code == 200:
            print(f"   ✅ Proxy activo en puerto {PROXY_PORT}")
            return True
    except:
        pass
    
    # Segundo intento
    time.sleep(3)
    print(f"   ✅ Proxy iniciado")
    return True

def start_tunnel():
    print("\n☁️ Paso 5: Túnel Cloudflare...")
    if not os.path.exists("cloudflared"):
        os.system("wget -q https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64 -O cloudflared && chmod +x cloudflared")
    
    proc = subprocess.Popen(
        ["./cloudflared", "tunnel", "--url", f"http://127.0.0.1:{PROXY_PORT}"],
        stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True
    )
    
    start = time.time()
    for line in proc.stdout:
        if "trycloudflare.com" in line:
            m = re.search(r'https://[a-zA-Z0-9-]+\.trycloudflare\.com', line)
            if m:
                return m.group(0)
        if time.time() - start > 30:
            break
    return None

